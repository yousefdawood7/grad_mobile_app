{
  "expo": {
    "name": "Water Hyacinth Classification",
    "slug": "water-hyacinth-classification",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "waterhyacinth",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.gradproject.waterhyacinth",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Water Hyacinth Classification to take photos for plant analysis.",
        "NSPhotoLibraryUsageDescription": "Allow Water Hyacinth Classification to choose photos for plant analysis."
      }
    },
    "android": {
      "package": "com.gradproject.waterhyacinth",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "extra": {
      "modelApiTimeoutMs": 15000,
      "modelApiUrl": "http://13.60.65.62:3000/predict",
      "supabaseUrl": "https://vejazwelilonndcsreop.supabase.co",
      "supabasePublishableKey": "sb_publishable_3PFTCbS3RCEpY12K35VB5A_4jhn0nAE"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-web-browser",
        {
          "experimentalLauncherActivity": false
        }
      ]
    ]
  }
}
